# ═══════════════════════════════════════════════════════════════════
#  QA Management System — Frontend Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# Backend API base URL — the Spring Boot server address
# For local development the default below is correct.
# For production, change to your deployed backend URL (e.g. https://api.yourdomain.com/api)
VITE_API_BASE_URL=http://localhost:8080/api
