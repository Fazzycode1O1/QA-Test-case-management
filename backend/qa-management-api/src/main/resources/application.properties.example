# Backend Configuration
# Copy this file to application.properties and customize for your environment

# Server Configuration
server.port=8080

# Database Configuration
# Update username and password if your MySQL uses different credentials
spring.datasource.url=jdbc:mysql://localhost:3306/qa_management_db
spring.datasource.username=root
spring.datasource.password=

# Hibernate/JPA Configuration
# ddl-auto=update: Automatically create/update tables (development only)
# For production, use ddl-auto=validate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# Security Configuration
# JWT secret: Set via environment variable QAMS_JWT_SECRET for security
# For local development, the fallback value is used if not set
# For production, set a strong random secret (min 32 characters)
security.jwt.secret=${QAMS_JWT_SECRET:qams-dev-secret-key-do-not-use-in-production-min-32-chars!!}

# JWT token expiration in milliseconds
# Default: 86400000 (24 hours)
# 604800000 = 7 days, 2592000000 = 30 days
security.jwt.expiration-ms=${QAMS_JWT_EXPIRATION_MS:86400000}

# CORS Configuration (if needed for different origins)
# Currently configured to allow http://localhost:5173
# Update in SecurityConfig.java if different frontend origin is needed
