# ═══════════════════════════════════════════════════════════════════
#  QA Management System — Backend Environment Variables
#  Copy this file to .env and fill in your Supabase values.
#  NEVER commit .env to git — it contains your real password.
# ═══════════════════════════════════════════════════════════════════

# ─── HOW TO GET THESE VALUES ──────────────────────────────────────
#
#  1. Go to https://supabase.com/dashboard
#  2. Click your project → left sidebar → Settings → Database
#  3. Scroll to the "Connection string" section
#  4. Click the "JDBC" tab
#  5. Copy the full string shown — that is your SUPABASE_DB_URL
#
#  The URL looks like:
#    jdbc:postgresql://db.xxxxxxxxxxxx.supabase.co:5432/postgres?user=postgres&password=...
#  Strip out the user= and password= parts — put them in the separate fields below.
#
#  SUPABASE_DB_USERNAME → always just "postgres" (for direct connection)
#  SUPABASE_DB_PASSWORD → Settings → Database → "Database Password" section
#                         (click "Reset database password" if you forgot it)
#
# ─── EXAMPLE (replace with your real values) ──────────────────────
#
#  SUPABASE_DB_URL      = jdbc:postgresql://db.ukxtofzranooqyhvvcle.supabase.co:5432/postgres?sslmode=require
#  SUPABASE_DB_USERNAME = postgres
#  SUPABASE_DB_PASSWORD = MyStr0ngP@ssword!
#
# ──────────────────────────────────────────────────────────────────

SUPABASE_DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD

# ─── CORS ─────────────────────────────────────────────────────────
# Frontend origin allowed to call the API.
# For local dev the default below is correct (Vite runs on 5173).
CORS_ALLOWED_ORIGIN=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────
# Change QAMS_JWT_SECRET to a strong random string before going to production.
QAMS_JWT_SECRET=qams-dev-secret-key-do-not-use-in-production-min-32-chars!!
QAMS_JWT_EXPIRATION_MS=86400000
